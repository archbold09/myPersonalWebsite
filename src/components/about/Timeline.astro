---
import type { Experience, Education } from '../../types';
import FadeInText from '@astroanimate/core/FadeInText';
import { techIcons } from '../../data/techIcons';

interface Props {
  items: (Experience | Education)[];
  type: 'experience' | 'education';
}

const { items, type } = Astro.props;

function isExperience(item: Experience | Education): item is Experience {
  return 'company' in item;
}

function getTechIconUrl(tech: string): string | null {
  return techIcons[tech]?.icon || null;
}
---

<div class="relative timeline-container">
  <!-- Timeline line -->
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary-500 via-accent-teal to-accent-cyan transform -translate-x-1/2"></div>

  <!-- Timeline items -->
  <div class="space-y-8">
    {items.map((item, index) => (
      <div class={`relative flex items-start gap-6 md:gap-0 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <!-- Timeline dot -->
        <div
          class="absolute left-4 md:left-1/2 w-4 h-4 -translate-x-1/2 rounded-full bg-primary-500 ring-4 ring-white dark:ring-slate-950 z-10 timeline-dot"
          style={`animation-delay: ${index * 150}ms`}
        ></div>

        <!-- Content -->
        <div class={`ml-12 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
          <FadeInText enhance duration={0.6} yOffset={30}>
            <div class="glass p-6 card-hover timeline-card">
              <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-primary-500/20 text-primary-600 dark:text-primary-400 mb-3">
                <span class="lang-es">{isExperience(item) ? (item.periodEs || item.period) : (item.periodEs || item.period)}</span>
                <span class="lang-en hidden">{isExperience(item) ? item.period : item.period}</span>
              </span>

              <h3 class="text-lg font-semibold mb-1 text-slate-900 dark:text-white">
                <span class="lang-es">{isExperience(item) ? (item.roleEs || item.role) : (item.degreeEs || item.degree)}</span>
                <span class="lang-en hidden">{isExperience(item) ? item.role : item.degree}</span>
              </h3>

              <p class="text-primary-600 dark:text-primary-400 text-sm mb-2">
                {isExperience(item) ? item.company : item.institution}
              </p>

              {isExperience(item) && item.description && (
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  <span class="lang-es">{item.descriptionEs || item.description}</span>
                  <span class="lang-en hidden">{item.description}</span>
                </p>
              )}

              {/* Career Progression */}
              {isExperience(item) && item.progression && item.progression.length > 0 && (
                <div class="mt-4 pt-3 border-t border-slate-200 dark:border-white/10">
                  <p class={`text-xs text-slate-500 dark:text-slate-500 mb-2 font-medium ${index % 2 === 0 ? 'md:text-right' : ''}`}>
                    <span class="lang-es">Trayectoria</span>
                    <span class="lang-en hidden">Career Path</span>
                  </p>
                  <div class={`space-y-2 ${index % 2 === 0 ? 'md:flex md:flex-col md:items-end' : ''}`}>
                    {item.progression.map((prog) => (
                      <div class={`flex items-center gap-2 text-xs ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                        <div class={`w-2 h-2 rounded-full flex-shrink-0 ${prog.current ? 'bg-primary-500' : 'bg-slate-400 dark:bg-slate-600'}`}></div>
                        <span class={`font-medium ${prog.current ? 'text-primary-600 dark:text-primary-400' : 'text-slate-600 dark:text-slate-400'}`}>
                          <span class="lang-es">{prog.roleEs || prog.role}</span>
                          <span class="lang-en hidden">{prog.role}</span>
                        </span>
                        <span class="text-slate-400 dark:text-slate-500">
                          <span class="lang-es">{prog.periodEs || prog.period}</span>
                          <span class="lang-en hidden">{prog.period}</span>
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Technology Icons */}
              {isExperience(item) && item.technologies && item.technologies.length > 0 && (
                <div class="mt-4 pt-3 border-t border-slate-200 dark:border-white/10">
                  <div class={`flex flex-wrap gap-2 ${index % 2 === 0 ? 'md:justify-end' : ''}`}>
                    {item.technologies.map((tech) => {
                      const iconUrl = getTechIconUrl(tech);
                      return (
                        <div
                          class="tech-icon-wrapper group relative flex items-center justify-center w-8 h-8 rounded-lg bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 transition-all duration-200 hover:scale-110"
                          title={tech}
                        >
                          {iconUrl ? (
                            <img
                              src={iconUrl}
                              alt={tech}
                              class="w-5 h-5"
                              loading="lazy"
                            />
                          ) : (
                            <span class="text-[10px] font-medium text-slate-600 dark:text-slate-400">{tech.substring(0, 2)}</span>
                          )}
                          <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 px-2 py-1 text-[10px] font-medium bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
                            {tech}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          </FadeInText>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .timeline-card {
    transition: all 0.3s ease;
  }

  .timeline-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 197, 142, 0.15);
  }

  .timeline-dot {
    animation: dot-pop-in 0.5s ease-out forwards;
    opacity: 0;
    transform: translateX(-50%) scale(0);
  }

  @keyframes dot-pop-in {
    0% {
      opacity: 0;
      transform: translateX(-50%) scale(0);
    }
    50% {
      transform: translateX(-50%) scale(1.2);
    }
    100% {
      opacity: 1;
      transform: translateX(-50%) scale(1);
    }
  }

  .timeline-dot:hover {
    transform: translateX(-50%) scale(1.3);
    box-shadow: 0 0 15px rgba(0, 197, 142, 0.5);
    transition: all 0.3s ease;
  }
</style>

<script>
  // Animate dots when they come into view
  function initTimelineDots() {
    const dots = document.querySelectorAll('.timeline-dot');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.animationPlayState = 'running';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    dots.forEach(dot => {
      (dot as HTMLElement).style.animationPlayState = 'paused';
      observer.observe(dot);
    });
  }

  initTimelineDots();
  document.addEventListener('astro:page-load', initTimelineDots);
</script>
