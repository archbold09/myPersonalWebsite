# pnpm security configuration

# Require exact versions to avoid supply chain attacks
save-exact=true

# Use strict peer dependencies
strict-peer-dependencies=true

# Verify package integrity
package-lock=true

# Only allow approved packages to run lifecycle scripts
# Scripts are managed via pnpm-workspace.yaml or approve-builds command
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=sharp
